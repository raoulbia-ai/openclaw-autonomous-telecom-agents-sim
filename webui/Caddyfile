{
    http_port 8888
    https_port 8000
}

openclaw-nka.duckdns.org:8000 {
    reverse_proxy localhost:9000 {
        flush_interval -1

        transport http {
            dial_timeout 5s
            response_header_timeout 30s
        }
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security "max-age=31536000"
        -Server
    }

    request_body {
        max_size 10MB
    }

    log {
        output file /tmp/nka-caddy-access.log {
            roll_size 10mb
            roll_keep 3
        }
    }
}
